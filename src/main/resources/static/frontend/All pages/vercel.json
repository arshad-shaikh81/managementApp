{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index" },

    { "source": "/home", "destination": "/ResidentPage/Home_page/homePage" },
    { "source": "/dashboard", "destination": "/ResidentPage/Dashboard/mainDashboard" },
    { "source": "/profile", "destination": "/ResidentPage/My_profile/profile" },
    { "source": "/login", "destination": "/RagistrationPages/Login_page/loginPage" },
    { "source": "/signup", "destination": "/RagistrationPages/Signin_page/signinPage" },
    { "source": "/register-society", "destination": "/RagistrationPages/Society_registration/societyRegistration" },
    { "source": "/forgot-password", "destination": "/RagistrationPages/ForgotPassword_page/forgotPasswordPage" },

    { "source": "/favicon.svg", "destination": "/favicon.svg" },

    { "source": "/homePage.css", "destination": "/ResidentPage/Home_page/homePage.css" },
    { "source": "/homePage.js", "destination": "/ResidentPage/Home_page/homePage.js" },
    { "source": "/mainDashboard.css", "destination": "/ResidentPage/Dashboard/mainDashboard.css" },
    { "source": "/mainDashboard.js", "destination": "/ResidentPage/Dashboard/mainDashboard.js" },
    { "source": "/profile.css", "destination": "/ResidentPage/My_profile/profile.css" },
    { "source": "/loginPage.css", "destination": "/RagistrationPages/Login_page/loginPage.css" },
    { "source": "/loginPage.js", "destination": "/RagistrationPages/Login_page/loginPage.js" },
    { "source": "/signinPage.css", "destination": "/RagistrationPages/Signin_page/signinPage.css" },
    { "source": "/signinPage.js", "destination": "/RagistrationPages/Signin_page/signinPage.js" },
    { "source": "/societyRegistration.css", "destination": "/RagistrationPages/Society_registration/societyRegistration.css" },
    { "source": "/societyRegistration.js", "destination": "/RagistrationPages/Society_registration/societyRegistration.js" },
    { "source": "/forgotPasswordPage.css", "destination": "/RagistrationPages/ForgotPassword_page/forgotPasswordPage.css" },
    { "source": "/forgotPasswordPage.js", "destination": "/RagistrationPages/ForgotPassword_page/forgotPasswordPage.js" }
  ]
}